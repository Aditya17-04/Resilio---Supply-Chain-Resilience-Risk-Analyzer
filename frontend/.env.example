# Google OAuth – create a project at https://console.cloud.google.com/
# Under "Credentials" create an OAuth 2.0 Client ID (Web application).
# Add these to "Authorised JavaScript origins":
# - http://localhost:3000
# - http://127.0.0.1:3000
# Optional (if you run on alternate port):
# - http://localhost:3001
# - http://127.0.0.1:3001
VITE_GOOGLE_CLIENT_ID=your-google-client-id-here.apps.googleusercontent.com

# Supabase – create a project at https://supabase.com
# Find URL and anon key under Project Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key-here
